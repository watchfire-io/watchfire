{
  "blocks": [
    {
      "type": "header",
      "text": {
        "type": "plain_text",
        "text": ":bar_chart: Watchfire — your week",
        "emoji": true
      }
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": {{ digestSnippet .DigestBody 800 | jsonStr }}
      }
    },
    {
      "type": "context",
      "elements": [
        {
          "type": "mrkdwn",
          "text": {{ printf ":bar_chart: Weekly digest · %s" (rfc3339 .EmittedAt) | jsonStr }}
        }
      ]
    },
    {
      "type": "actions",
      "elements": [
        {
          "type": "button",
          "text": {
            "type": "plain_text",
            "text": "Open digest",
            "emoji": true
          },
          "url": {{ .DeepLink | jsonStr }}
        }
      ]
    }
  ]
}

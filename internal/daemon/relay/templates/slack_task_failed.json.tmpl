{
  "blocks": [
    {
      "type": "header",
      "text": {
        "type": "plain_text",
        "text": {{ printf ":rotating_light: Task failed — %s" .ProjectName | jsonStr }},
        "emoji": true
      }
    },
    {
      "type": "section",
      "text": {
        "type": "mrkdwn",
        "text": {{ printf "*Task #%04d*: %s\n*Reason*: %s" .TaskNumber .TaskTitle .TaskFailureReason | jsonStr }}
      }
    },
    {
      "type": "context",
      "elements": [
        {
          "type": "mrkdwn",
          "text": {{ printf "%s %s · %s" (slackEmoji .ProjectColor) .ProjectName (rfc3339 .EmittedAt) | jsonStr }}
        }
      ]
    },
    {
      "type": "actions",
      "block_id": {{ printf "watchfire_task_%s_%d" .ProjectID .TaskNumber | jsonStr }},
      "elements": [
        {
          "type": "button",
          "action_id": "watchfire_retry",
          "style": "primary",
          "text": {
            "type": "plain_text",
            "text": "Retry",
            "emoji": true
          },
          "value": {{ printf "%s|%d" .ProjectID .TaskNumber | jsonStr }}
        },
        {
          "type": "button",
          "action_id": "watchfire_cancel",
          "style": "danger",
          "text": {
            "type": "plain_text",
            "text": "Cancel",
            "emoji": true
          },
          "value": {{ printf "%s|%d" .ProjectID .TaskNumber | jsonStr }}
        },
        {
          "type": "button",
          "action_id": "watchfire_view",
          "text": {
            "type": "plain_text",
            "text": "View in Watchfire",
            "emoji": true
          },
          "url": {{ .DeepLink | jsonStr }}
        }
      ]
    }
  ]
}
